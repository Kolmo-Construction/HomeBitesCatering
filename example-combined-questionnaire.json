{
  "definition": {
    "title": "Event Planning Questionnaire", 
    "description": "Help us understand your event needs",
    "versionName": "v1.0",
    "isActive": true
  },
  "pages": [
    {
      "title": "Basic Information",
      "description": "Let's start with the basics",
      "order": 1,
      "questions": [
        {
          "questionText": "What type of event are you planning?",
          "questionKey": "event_type",
          "questionType": "select",
          "isRequired": true,
          "order": 1,
          "options": [
            { "optionText": "Wedding", "optionValue": "wedding", "order": 1 },
            { "optionText": "Corporate Event", "optionValue": "corporate", "order": 2 },
            { "optionText": "Birthday Party", "optionValue": "birthday", "order": 3 },
            { "optionText": "Other", "optionValue": "other", "order": 4 }
          ]
        },
        {
          "questionText": "Approximately how many guests will attend?",
          "questionKey": "guest_count",
          "questionType": "number",
          "isRequired": true,
          "order": 2
        },
        {
          "questionText": "What is the tentative date of your event?",
          "questionKey": "event_date",
          "questionType": "date",
          "isRequired": true,
          "order": 3
        }
      ]
    },
    {
      "title": "Contact Information",
      "description": "Your contact details",
      "order": 2,
      "questions": [
        {
          "questionText": "Your name",
          "questionKey": "name",
          "questionType": "text",
          "isRequired": true,
          "order": 1
        },
        {
          "questionText": "Email address",
          "questionKey": "email",
          "questionType": "email", 
          "isRequired": true,
          "order": 2
        },
        {
          "questionText": "Phone number",
          "questionKey": "phone",
          "questionType": "tel",
          "isRequired": false,
          "order": 3
        }
      ]
    },
    {
      "title": "Venue Details",
      "description": "Tell us about your venue",
      "order": 3,
      "questions": [
        {
          "questionText": "Do you have a venue already selected?",
          "questionKey": "has_venue",
          "questionType": "radio",
          "isRequired": true,
          "order": 1,
          "options": [
            { "optionText": "Yes", "optionValue": "yes", "order": 1 },
            { "optionText": "No", "optionValue": "no", "order": 2 }
          ]
        },
        {
          "questionText": "Venue name (if known)",
          "questionKey": "venue_name",
          "questionType": "text",
          "isRequired": false,
          "order": 2
        },
        {
          "questionText": "Venue address (if known)",
          "questionKey": "venue_address",
          "questionType": "textarea",
          "isRequired": false,
          "order": 3
        }
      ]
    },
    {
      "title": "Catering Requirements",
      "description": "Food and beverage preferences",
      "order": 4,
      "questions": [
        {
          "questionText": "What type of service are you interested in?",
          "questionKey": "service_type",
          "questionType": "select",
          "isRequired": true,
          "order": 1,
          "options": [
            { "optionText": "Full-service catering", "optionValue": "full", "order": 1 },
            { "optionText": "Drop-off catering", "optionValue": "drop_off", "order": 2 },
            { "optionText": "Food station setup", "optionValue": "station", "order": 3 },
            { "optionText": "Not sure yet", "optionValue": "unsure", "order": 4 }
          ]
        },
        {
          "questionText": "Are there any dietary restrictions we should be aware of?",
          "questionKey": "dietary_restrictions",
          "questionType": "multiselect",
          "isRequired": false,
          "order": 2,
          "options": [
            { "optionText": "Vegetarian", "optionValue": "vegetarian", "order": 1 },
            { "optionText": "Vegan", "optionValue": "vegan", "order": 2 },
            { "optionText": "Gluten-free", "optionValue": "gluten_free", "order": 3 },
            { "optionText": "Dairy-free", "optionValue": "dairy_free", "order": 4 },
            { "optionText": "Nut allergies", "optionValue": "nut_allergies", "order": 5 },
            { "optionText": "Other (please specify)", "optionValue": "other", "order": 6 }
          ]
        },
        {
          "questionText": "Please specify other dietary restrictions or allergies",
          "questionKey": "other_dietary",
          "questionType": "textarea",
          "isRequired": false,
          "order": 3,
          "placeholderText": "Please list any other dietary needs or allergies here"
        }
      ]
    },
    {
      "title": "Additional Information",
      "description": "Any other details you'd like to share",
      "order": 5,
      "questions": [
        {
          "questionText": "How did you hear about us?",
          "questionKey": "referral_source",
          "questionType": "select",
          "isRequired": false,
          "order": 1,
          "options": [
            { "optionText": "Google search", "optionValue": "google", "order": 1 },
            { "optionText": "Social media", "optionValue": "social", "order": 2 },
            { "optionText": "Referral", "optionValue": "referral", "order": 3 },
            { "optionText": "Past client", "optionValue": "past_client", "order": 4 },
            { "optionText": "Other", "optionValue": "other", "order": 5 }
          ]
        },
        {
          "questionText": "Any additional comments or requests?",
          "questionKey": "comments",
          "questionType": "textarea",
          "isRequired": false,
          "order": 2,
          "placeholderText": "Please share any other details that would help us understand your needs"
        }
      ]
    }
  ],
  "conditionalLogic": [
    {
      "description": "Only ask for 'other dietary restrictions' if 'Other' is selected",
      "condition": "dietary_restrictions && dietary_restrictions.includes('other')",
      "action": "show_question",
      "targetQuestionKey": "other_dietary"
    },
    {
      "description": "Only show venue details questions if they have a venue",
      "condition": "has_venue === 'yes'",
      "action": "show_questions",
      "targetQuestionKeys": ["venue_name", "venue_address"]
    },
    {
      "description": "Skip to catering requirements if no venue selected",
      "condition": "has_venue === 'no'",
      "action": "jump_to_page",
      "targetPageIndex": 3
    }
  ]
}